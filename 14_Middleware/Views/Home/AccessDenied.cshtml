@{
    ViewData["Title"] = "Erişim Reddedildi";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white text-center">
                    <h2><i class="fas fa-lock"></i> Erişim Reddedildi</h2>
                </div>
                <div class="card-body text-center">
                    <div class="mb-4">
                        <i class="fas fa-shield-alt fa-5x text-danger"></i>
                    </div>
                    <h4>🚫 Bu alana erişim yetkiniz bulunmuyor!</h4>
                    <p class="lead">Bu sayfa <strong>SimpleAuth Middleware</strong> tarafından korunmaktadır.</p>
                    <p>Erişim için önce giriş yapmanız gerekmektedir.</p>

                    <hr>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="card bg-light">
                                <div class="card-body">
                                    <h6><i class="fas fa-info-circle"></i> Bilgi</h6>
                                    <p class="small">Middleware sistemi çalışıyor ve yetkisiz erişimleri engelliyor.</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="card bg-light">
                                <div class="card-body">
                                    <h6><i class="fas fa-key"></i> Giriş Bilgileri</h6>
                                    <p class="small">Kullanıcı: <code>admin</code><br>Şifre: <code>123</code></p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4">
                        <a href="@Url.Action("Login", "Home")" class="btn btn-primary btn-lg">
                            <i class="fas fa-sign-in-alt"></i> Giriş Yap
                        </a>
                        <a href="/Home/Index" class="btn btn-secondary btn-lg">
                            <i class="fas fa-home"></i> Ana Sayfa
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

