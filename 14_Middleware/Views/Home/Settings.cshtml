
@{
    ViewData["Title"] = "Settings";
}

<div class="alert alert-info">
    <h4>⚙️ Ayarlar</h4>
    <p>Sistem ayarları buradan yönetilebilir.</p>
</div>

<div class="card">
    <div class="card-body">
        <h6>🔧 Middleware Ayarları</h6>
        <div class="form-check">
            <input class="form-check-input" type="checkbox" checked disabled>
            <label class="form-check-label">Error Handling Middleware</label>
        </div>
        <div class="form-check">
            <input class="form-check-input" type="checkbox" checked disabled>
            <label class="form-check-label">Visitor Counter Middleware</label>
        </div>
        <div class="form-check">
            <input class="form-check-input" type="checkbox" checked disabled>
            <label class="form-check-label">Request Time Middleware</label>
        </div>
        <div class="form-check">
            <input class="form-check-input" type="checkbox" checked disabled>
            <label class="form-check-label">Simple Auth Middleware</label>
        </div>
    </div>
</div>

