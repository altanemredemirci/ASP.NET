@{
    ViewData["Title"] = "Home Page";
}

<div class="jumbotron bg-light p-5 rounded">
    <h1 class="display-4">ASP.NET CORE Middleware Demo</h1>
    <p class="lead">Bu proje farklı middleware'lerin nasıl çalıştığını gösterir.</p>
</div>

<div class="row mt-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5>📊 Aktif Middleware'ler</h5>
            </div>
            <div class="card-body">
                <ul class="list-group list-group-flush">
                    <li class="list-group-item">🛡️ Error Handling Middleware</li>
                    <li class="list-group-item">👥 Visitor Counter Middleware</li>
                    <li class="list-group-item">⏱️ Request Time Middleware</li>
                    <li class="list-group-item">🔒 Simple Auth Middleware</li>
                </ul>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5>🔗 Test Sayfaları</h5>
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    <a href="/Home/Login" class="btn btn-primary">🔑 Giriş Yap</a>
                    <a href="/Home/Dashboard" class="btn btn-warning">📊 Dashboard (Korumalı)</a>
                    <a href="/Home/Admin" class="btn btn-danger">🔒 Admin (Korumalı)</a>
                    <a href="/Home/Settings" class="btn btn-info">⚙️ Ayarlar (Korumalı)</a>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="middleware-info mt-4">
    <h6>📈 Ziyaretçi İstatistikleri</h6>
    <p><strong>Toplam Ziyaretçi:</strong> @(ViewBag.TotalVisitors ?? 0)</p>
    <p><strong>Bu Sayfa:</strong> @(ViewBag.CurrentPageVisits ?? 0) kez ziyaret edildi</p>
</div>